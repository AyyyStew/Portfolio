---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import { projects } from "../data/projects";
import { professionalProjects } from "../data/professionalProjects";
import { siteConfig } from "../data/site";
import { skillGroups } from "../data/skills";
import type { Project } from "../data/projects";

const featuredProjects = projects.slice(0, 3);
const extraProjects = projects.slice(3);
const skillsNote = "note" in siteConfig.skills ? siteConfig.skills.note : undefined;

const getProjectTitleHref = (project: Project) => project.projectUrl ?? project.githubUrl;
const getProjectThumbnailHref = (project: Project) => project.projectUrl ?? project.githubUrl;

const sections = [
  { id: "intro", label: "Intro", icon: "intro" },
  { id: "professional-projects", label: "Professional", icon: "briefcase" },
  { id: "projects", label: "Personal", icon: "spark" },
  { id: "skills", label: "Skills", icon: "skills" },
  { id: "contact", label: "Contact", icon: "email" }
] as const;
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <div class="page-shell">
    <header class="hero" id="intro">
      <nav class="site-nav" aria-label="Section navigation">
        <div class="site-nav__top">
          <a class="brand" href="#intro">{siteConfig.name}</a>
          <button
            type="button"
            class="site-nav__toggle"
            aria-expanded="false"
            aria-controls="site-nav-links"
            aria-label="Open navigation menu"
          >
            <Icon name="menu" class="ui-icon ui-icon--nav-toggle site-nav__toggle-icon site-nav__toggle-icon--menu" />
            <Icon name="x" class="ui-icon ui-icon--nav-toggle site-nav__toggle-icon site-nav__toggle-icon--close" />
          </button>
        </div>
        <div class="site-nav__links" id="site-nav-links">
          {
            sections.map((section) => (
              <a href={`#${section.id}`}>
                <Icon name={section.icon} class="ui-icon ui-icon--nav" />
                <span>{section.label}</span>
              </a>
            ))
          }
        </div>
      </nav>

      <section class="hero__content">
        <div class="hero__main">
          <h1>{siteConfig.name}</h1>
          <p class="lede">{siteConfig.intro.heading}</p>
          <div class="hero__body">
            <p>
              My background spans software, infrastructure, embedded systems, networking,
              cybersecurity, and research.{" "}
              <span class="copy-emphasis">Different problems demand different tools.</span>
            </p>
            <p>{siteConfig.intro.body[1]}</p>
          </div>
          <a class="contact-button contact-button--hero" href={`mailto:${siteConfig.email}`}>
            <Icon name="email" class="ui-icon" />
            <span>Get in touch</span>
          </a>
        </div>
      </section>
    </header>



      <section class="section-block" id="professional-projects">
        <div class="section-heading">
          <h2 class="section-title">
            <Icon name="briefcase" class="ui-icon ui-icon--section" />
            <span>{siteConfig.professionalProjects.heading}</span>
          </h2>
          <p>{siteConfig.professionalProjects.note}</p>
        </div>

        <p class="section-disclaimer">{siteConfig.professionalProjects.disclaimer}</p>

        {professionalProjects.length > 0 ? (
          <ul class="professional-project-list">
            {professionalProjects.map((project, index) => (
              <li class="professional-project-item">
                <div class="professional-project-item__meta">0{index + 1}</div>
                <div class="professional-project-item__body">
                  <h3>{project.title}</h3>
                  <p>{project.summary}</p>
                </div>
              </li>
            ))}
          </ul>
        ) : (
          <p class="professional-project-empty">{siteConfig.professionalProjects.empty}</p>
        )}
      </section>

      <section class="section-block" id="projects">
        <div class="section-heading">
          <h2 class="section-title">
            <Icon name="spark" class="ui-icon ui-icon--section" />
            <span>{siteConfig.projects.heading}</span>
          </h2>
          <p>{siteConfig.projects.note}</p>
        </div>

        <div class="project-list">
          {
            featuredProjects.map((project, index) => (
              <article class:list={["project-card", { "project-card--with-media": Boolean(project.thumbnail) }]}>
                <div class="project-card__meta">0{index + 1}</div>
                <div class="project-card__main">
                  <div class="project-card__top">
                    <div class="project-card__header">
                      <div class="project-card__heading">
                        {getProjectTitleHref(project) ? (
                          <h3>
                            <a href={getProjectTitleHref(project)} target="_blank" rel="noreferrer">
                              {project.title}
                            </a>
                          </h3>
                        ) : (
                          <h3>{project.title}</h3>
                        )}
                      </div>
                      <p>{project.summary}</p>
                    </div>
                    <div class="project-card__actions">
                      {project.projectUrl && (
                        <a class="project-card__action-link" href={project.projectUrl} target="_blank" rel="noreferrer">
                          <Icon name="spark" class="ui-icon ui-icon--link" />
                          <span>Live</span>
                        </a>
                      )}
                      {project.githubUrl && (
                        <a class="project-card__action-link" href={project.githubUrl} target="_blank" rel="noreferrer">
                          <Icon name="github" class="ui-icon ui-icon--link" />
                          <span>Repo</span>
                        </a>
                      )}
                    </div>
                  </div>
                  {project.thumbnail && (
                    <div class="project-card__artifact">
                      <div class="project-card__media">
                        <div class="project-card__media-frame">
                          {getProjectThumbnailHref(project) ? (
                            <button
                              type="button"
                              class="project-card__media-link"
                              data-lightbox-src={project.thumbnail.src}
                              data-lightbox-alt={project.thumbnail.alt}
                              data-lightbox-title={project.title}
                              aria-label={`Expand ${project.title} preview`}
                            >
                              <img
                                src={project.thumbnail.src}
                                alt={project.thumbnail.alt}
                                loading="lazy"
                              />
                            </button>
                          ) : (
                            <img
                              src={project.thumbnail.src}
                              alt={project.thumbnail.alt}
                              loading="lazy"
                            />
                          )}
                        </div>
                      </div>
                    </div>
                  )}
                  <div class:list={["project-card__support", { "project-card__support--text-only": !project.thumbnail }]}>
                    <p class="project-card__detail">
                      <span class="project-card__label">Why?</span>
                      <span>{project.why}</span>
                    </p>
                    <p class="project-card__detail project-card__learned">
                      <span class="project-card__label">Learned</span>
                      <span>{project.learned}</span>
                    </p>
                  </div>
                </div>
              </article>
            ))
          }
        </div>

        {extraProjects.length > 0 && (
          <details class="project-overflow">
            <summary>Show {extraProjects.length} more project{extraProjects.length === 1 ? "" : "s"}</summary>
            <div class="project-list project-list--extra">
              {
                extraProjects.map((project, index) => (
                  <article class:list={["project-card", { "project-card--with-media": Boolean(project.thumbnail) }]}>
                    <div class="project-card__meta">
                      0{featuredProjects.length + index + 1}
                    </div>
                    <div class="project-card__main">
                      <div class="project-card__top">
                        <div class="project-card__header">
                          <div class="project-card__heading">
                            {getProjectTitleHref(project) ? (
                              <h3>
                                <a href={getProjectTitleHref(project)} target="_blank" rel="noreferrer">
                                  {project.title}
                                </a>
                              </h3>
                            ) : (
                              <h3>{project.title}</h3>
                            )}
                          </div>
                          <p>{project.summary}</p>
                        </div>
                        <div class="project-card__actions">
                          {project.projectUrl && (
                            <a class="project-card__action-link" href={project.projectUrl} target="_blank" rel="noreferrer">
                              <Icon name="spark" class="ui-icon ui-icon--link" />
                              <span>Live</span>
                            </a>
                          )}
                          {project.githubUrl && (
                            <a class="project-card__action-link" href={project.githubUrl} target="_blank" rel="noreferrer">
                              <Icon name="github" class="ui-icon ui-icon--link" />
                              <span>Repo</span>
                            </a>
                          )}
                        </div>
                      </div>
                      {project.thumbnail && (
                        <div class="project-card__artifact">
                          <div class="project-card__media">
                            <div class="project-card__media-frame">
                              {getProjectThumbnailHref(project) ? (
                                <button
                                  type="button"
                                  class="project-card__media-link"
                                  data-lightbox-src={project.thumbnail.src}
                                  data-lightbox-alt={project.thumbnail.alt}
                                  data-lightbox-title={project.title}
                                  aria-label={`Expand ${project.title} preview`}
                                >
                                  <img
                                    src={project.thumbnail.src}
                                    alt={project.thumbnail.alt}
                                    loading="lazy"
                                  />
                                </button>
                              ) : (
                                <img
                                  src={project.thumbnail.src}
                                  alt={project.thumbnail.alt}
                                  loading="lazy"
                                />
                              )}
                            </div>
                          </div>
                        </div>
                      )}
                      <div class:list={["project-card__support", { "project-card__support--text-only": !project.thumbnail }]}>
                        <p class="project-card__detail">
                          <span class="project-card__label">Why?</span>
                          <span>{project.why}</span>
                        </p>
                        <p class="project-card__detail project-card__learned">
                          <span class="project-card__label">Learned</span>
                          <span>{project.learned}</span>
                        </p>
                      </div>
                    </div>
                  </article>
                ))
              }
            </div>
          </details>
        )}
      </section>

      <section class="section-block" id="skills">
        <div class="section-heading">
          <h2 class="section-title">
            <Icon name="skills" class="ui-icon ui-icon--section" />
            <span>{siteConfig.skills.heading}</span>
          </h2>
          {skillsNote && <p>{skillsNote}</p>}
        </div>

        <div class="skills-list">
          {
            skillGroups.map((group) => (
              <article class="skill-group">
                <h3>{group.title}</h3>
                <ul>
                  {group.items.map((item) => <li>{item}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section-block" id="contact">
        <div class="section-heading">
          <h2 class="section-title">
            <Icon name="email" class="ui-icon ui-icon--section" />
            <span>{siteConfig.contact.heading}</span>
          </h2>
          <p>
            The best way to reach me is by <span class="copy-emphasis">email</span>.
          </p>
        </div>

        <div class="contact-primary">
          <a class="contact-button contact-button--footer" href={`mailto:${siteConfig.email}`}>
            <Icon name="email" class="ui-icon" />
            <span>Email me</span>
          </a>
        </div>

        <div class="contact-secondary">
          <p class="contact-secondary__label">Elsewhere</p>
          <div class="contact-secondary__links">
            <a class="secondary-link" href={siteConfig.github} target="_blank" rel="noreferrer">
              <Icon name="github" class="ui-icon ui-icon--link" />
              <span>GitHub</span>
            </a>
            <a class="secondary-link" href={siteConfig.linkedin} target="_blank" rel="noreferrer">
              <Icon name="linkedin" class="ui-icon ui-icon--link" />
              <span>LinkedIn</span>
            </a>
          </div>
        </div>
      </section>

      <dialog class="lightbox" aria-label="Expanded project media">
        <div class="lightbox__inner">
          <form method="dialog" class="lightbox__close-row">
            <button type="submit" class="lightbox__close" aria-label="Close preview">
              <Icon name="x" class="ui-icon ui-icon--lightbox-close" />
            </button>
          </form>
          <figure class="lightbox__figure">
            <img class="lightbox__image" alt="" />
            <figcaption class="lightbox__caption"></figcaption>
          </figure>
        </div>
      </dialog>
    </main>
  </div>

  <script>
    const nav = document.querySelector(".site-nav");
    const navToggle = document.querySelector(".site-nav__toggle");
    const navLinks = document.querySelector(".site-nav__links");
    const lightbox = document.querySelector(".lightbox");
    const lightboxImage = lightbox?.querySelector(".lightbox__image");
    const lightboxCaption = lightbox?.querySelector(".lightbox__caption");
    const lightboxTriggers = document.querySelectorAll(".project-card__media-link[data-lightbox-src]");

    if (nav instanceof HTMLElement && navToggle instanceof HTMLButtonElement && navLinks instanceof HTMLElement) {
      const closeNav = () => {
        nav.dataset.navOpen = "false";
        navToggle.setAttribute("aria-expanded", "false");
      };

      navToggle.addEventListener("click", () => {
        const isOpen = nav.dataset.navOpen === "true";
        nav.dataset.navOpen = isOpen ? "false" : "true";
        navToggle.setAttribute("aria-expanded", isOpen ? "false" : "true");
      });

      navLinks.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", closeNav);
      });

      window.addEventListener("resize", () => {
        if (window.innerWidth > 720) {
          closeNav();
        }
      });
    }

    if (lightbox instanceof HTMLDialogElement && lightboxImage instanceof HTMLImageElement && lightboxCaption instanceof HTMLElement) {
      lightboxTriggers.forEach((trigger) => {
        trigger.addEventListener("click", () => {
          const src = trigger.getAttribute("data-lightbox-src");
          const alt = trigger.getAttribute("data-lightbox-alt") ?? "";
          const title = trigger.getAttribute("data-lightbox-title") ?? "";

          if (!src) return;

          lightboxImage.src = src;
          lightboxImage.alt = alt;
          lightboxCaption.textContent = title;
          lightbox.showModal();
        });
      });

      lightbox.addEventListener("click", (event) => {
        if (event.target === lightbox) {
          lightbox.close();
        }
      });

      lightbox.addEventListener("close", () => {
        lightboxImage.src = "";
        lightboxImage.alt = "";
        lightboxCaption.textContent = "";
      });
    }
  </script>
</BaseLayout>
