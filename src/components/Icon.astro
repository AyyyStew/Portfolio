---
type IconName =
  | "arrow-up-right"
  | "email"
  | "github"
  | "intro"
  | "linkedin"
  | "note"
  | "skills";

type Props = {
  name: IconName;
  class?: string;
};

const { name, class: className } = Astro.props;
---

{
  name === "email" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className}>
      <path d="M3 6.75h18v10.5H3z" fill="none" stroke="currentColor" stroke-width="1.8" />
      <path d="m4.5 8.25 7.5 5.25 7.5-5.25" fill="none" stroke="currentColor" stroke-width="1.8" />
    </svg>
  )
}
{
  name === "github" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className}>
      <path
        d="M12 3.5a8.5 8.5 0 0 0-2.69 16.57c.43.08.58-.18.58-.41v-1.43c-2.36.51-2.86-1-2.86-1-.39-.98-.95-1.24-.95-1.24-.78-.53.06-.52.06-.52.86.06 1.31.88 1.31.88.77 1.31 2.01.93 2.5.71.08-.56.3-.93.54-1.15-1.88-.21-3.86-.94-3.86-4.17 0-.92.33-1.67.87-2.26-.09-.21-.38-1.07.08-2.23 0 0 .71-.23 2.32.86A8.1 8.1 0 0 1 12 7.58a8.1 8.1 0 0 1 2.11.28c1.61-1.09 2.32-.86 2.32-.86.46 1.16.17 2.02.08 2.23.54.59.87 1.34.87 2.26 0 3.24-1.99 3.95-3.88 4.16.31.27.58.79.58 1.6v2.37c0 .23.15.49.58.41A8.5 8.5 0 0 0 12 3.5Z"
        fill="currentColor"
      />
    </svg>
  )
}
{
  name === "linkedin" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className}>
      <path
        d="M5.5 8.5h3v10h-3zm1.5-4a1.75 1.75 0 1 1 0 3.5 1.75 1.75 0 0 1 0-3.5Zm4.5 4h2.87v1.37h.04c.4-.76 1.38-1.56 2.84-1.56 3.03 0 3.59 1.99 3.59 4.58v5.61h-3v-4.97c0-1.19-.02-2.73-1.66-2.73-1.67 0-1.92 1.3-1.92 2.64v5.06h-3z"
        fill="currentColor"
      />
    </svg>
  )
}
{
  name === "arrow-up-right" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className}>
      <path d="M7 17 17 7M9 7h8v8" fill="none" stroke="currentColor" stroke-width="1.8" />
    </svg>
  )
}
{
  name === "intro" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className}>
      <circle cx="12" cy="12" r="8" fill="none" stroke="currentColor" stroke-width="1.8" />
      <path d="M12 8v4l3 2" fill="none" stroke="currentColor" stroke-width="1.8" />
    </svg>
  )
}
{
  name === "note" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className}>
      <path d="M6 4.5h12v15H6z" fill="none" stroke="currentColor" stroke-width="1.8" />
      <path d="M9 9h6M9 13h6M9 17h4" fill="none" stroke="currentColor" stroke-width="1.8" />
    </svg>
  )
}
{
  name === "skills" && (
    <svg viewBox="0 0 24 24" aria-hidden="true" class={className}>
      <path d="m14.5 6.5 3 3-8 8-3.5.5.5-3.5z" fill="none" stroke="currentColor" stroke-width="1.8" />
      <path d="m13 8 3 3" fill="none" stroke="currentColor" stroke-width="1.8" />
    </svg>
  )
}
